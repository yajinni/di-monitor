{
  "name": "di-monitor",
  "version": "3.3.0-beta",
  "description": "System tray app that receives PR values from Loot Manager and updates WoW addon SavedVariables",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^23.6.0",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.dimonitor.app",
    "productName": "DI Monitor",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "certificateFile": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DI Monitor"
    }
  }
}
